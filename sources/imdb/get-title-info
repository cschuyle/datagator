#!/usr/bin/env python3
# Usage: get-title-info tt0499097 [tt1234567 ...]
#        echo tt0499097 | get-title-info

import json
import sys
import urllib.request
import urllib.error

# Maps the `qid` field from the IMDB suggestion API to display strings.
# The `q` field (e.g. "TV series") is not used because it returns
# "feature" for movies rather than "Movie".
TYPE_MAP = {
    "movie": "Movie",
    "tvMovie": "TV Movie",
    "tvSeries": "TV Series",
    "tvMiniSeries": "TV Mini Series",
    "tvShort": "TV Short",
    "tvSpecial": "TV Special",
    "short": "Short",
    "videoGame": "Video Game",
    "video": "Video",
    "podcast": "Podcast",
    "podcastSeries": "Podcast Series",
}

SUGGESTION_URL = "https://v3.sg.media-imdb.com/suggestion/t/{id}.json"


def fetch_suggestion(imdb_id):
    url = SUGGESTION_URL.format(id=imdb_id)
    req = urllib.request.Request(url, headers={"Accept": "application/json"})
    with urllib.request.urlopen(req, timeout=15) as resp:
        return json.loads(resp.read())


def process(imdb_id):
    imdb_id = imdb_id.strip()
    if not imdb_id:
        return
    try:
        data = fetch_suggestion(imdb_id)
    except urllib.error.HTTPError as e:
        print(f"{imdb_id}\tERROR HTTP {e.code}", file=sys.stderr)
        return
    except Exception as e:
        print(f"{imdb_id}\tERROR {e}", file=sys.stderr)
        return

    results = data.get("d", [])
    match = next((r for r in results if r.get("id") == imdb_id), None)
    if match is None:
        print(f"{imdb_id}\tERROR no exact match in results", file=sys.stderr)
        return

    qid = match.get("qid", "")
    title_type = TYPE_MAP.get(qid, qid or "Unknown")
    name = match.get("l", "Unknown")
    year = match.get("y", "????")
    print(f"{title_type}\t{name} ({year})")


def main():
    if len(sys.argv) > 1:
        ids = sys.argv[1:]
    else:
        ids = sys.stdin.read().splitlines()

    for imdb_id in ids:
        process(imdb_id)


if __name__ == "__main__":
    main()
